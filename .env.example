# WorldMind play-server base URL (no trailing slash required)
# Local dev: omit — Vite proxies /api + core /assets/* to play-server (same-origin, no CORS).
# Direct core URL (needs WM_CORS_ORIGIN on play-server):
# VITE_WORLDMIND_CORE_URL=http://127.0.0.1:8080

# Production Pages build: omit (recommended) — Worker proxies same-origin /api/*
# Optional same-host override:
# VITE_WORLDMIND_CORE_URL=https://worldmind.tekup.dk