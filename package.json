{
  "name": "worldmind-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "node --import tsx --test test/**/*.test.ts",
    "bake:3d-models": "node scripts/bake-district-3d-models.mjs",
    "preview": "vite preview",
    "optimize:assets": "node scripts/optimize-assets.mjs",
    "cf:login": "wrangler login",
    "cf:whoami": "wrangler whoami",
    "cf:init": "wrangler pages project create worldmind-site --production-branch=main",
    "cf:git": "node scripts/setup-pages-git.mjs",
    "cf:deploy": "node scripts/trigger-deployment.mjs worldmind-site",
    "cf:domain": "node scripts/add-pages-domain.mjs",
    "cf:status": "node scripts/cloudflare-status.mjs",
    "cf:dns": "node scripts/fix-pages-dns.mjs",
    "cf:build": "node scripts/update-pages-build.mjs",
    "cf:migrate-domain": "node scripts/migrate-to-pages-domain.mjs",
    "cf:cleanup-runs": "node scripts/cleanup-github-runs.mjs",
    "cf:verify": "node scripts/verify-production.mjs",
    "verify:production": "node scripts/verify-production.mjs",
    "deploy:local": "npm run build && wrangler pages deploy dist --project-name=worldmind-site --commit-dirty=true",
    "deploy:worker": "wrangler deploy -c wrangler.worker.toml",
    "deploy": "node scripts/trigger-deployment.mjs worldmind-site"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "framer-motion": "^12.40.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "three": "^0.172.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.172.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "sharp": "^0.35.1",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.20.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wrangler": "^4.100.0"
  }
}
